<%- include('partials/header') %>
<div class="pb-2 mt-2 mb-4 border-bottom">
  <h3><%= event.title %>
    <% if (isPast) { %><span class="badge badge-secondary">已结束</span><% } %>
  </h3>
</div>

<div class="row">
  <div class="col-md-8">
    <table class="table table-sm table-borderless">
      <tr><th class="text-nowrap" style="width:6rem">时间</th><td><%= event.date %> <%= event.time %></td></tr>
      <tr><th>地点</th><td><%= event.location %></td></tr>
      <tr><th>说明</th><td><%= event.description %></td></tr>
    </table>

    <% if (!isPast) { %>
      <% if (signedUp) { %>
        <form method="POST" action="/event/<%= event.id %>/withdraw" class="mb-3">
          <button class="btn btn-outline-danger" type="submit">取消报名</button>
          <span class="text-success ml-2">✓ 你已报名</span>
        </form>
        <% if (event.coords) { %>
          <div class="mb-4">
            <% if (checkedIn) { %>
              <span class="badge badge-success p-2">✓ 已到场签到</span>
            <% } else { %>
              <button class="btn btn-success" id="checkin-btn" type="button">📍 到场签到</button>
              <small class="text-muted ml-2">需开启手机定位，且在球场 10 米范围内</small>
              <div id="checkin-msg" class="mt-2"></div>
            <% } %>
          </div>
        <% } %>
      <% } else if (event.signups.length >= event.capacity) { %>
        <p class="text-danger mb-4">报名人数已满</p>
      <% } else { %>
        <form method="POST" action="/event/<%= event.id %>/signup" class="mb-4">
          <button class="btn btn-primary" type="submit">报名</button>
        </form>
      <% } %>
    <% } %>

    <h5 class="border-bottom pb-2">留言 (<%= event.comments.length %>)</h5>
    <% event.comments.forEach(c => { %>
      <div class="media mb-2">
        <div class="media-body">
          <strong><%= c.author %></strong> <small class="text-muted"><%= c.time %></small>
          <p class="mb-1"><%= c.text %></p>
        </div>
      </div>
    <% }) %>
    <form method="POST" action="/event/<%= event.id %>/comment" class="mt-3 mb-4">
      <div class="form-group">
        <textarea class="form-control" name="text" rows="2" placeholder="写点什么…" required></textarea>
      </div>
      <button class="btn btn-sm btn-outline-primary" type="submit">发表留言</button>
    </form>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-header">报名名单 (<%= participants.length %> / <%= event.capacity %>)</div>
      <ul class="list-group list-group-flush">
        <% if (participants.length === 0) { %>
          <li class="list-group-item text-muted">还没有人报名</li>
        <% } %>
        <% participants.forEach((p, i) => { %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span><%= i + 1 %>. <%= p.name %></span>
            <% if (p.checkedIn) { %><span class="badge badge-success">已签到</span><% } %>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>
</div>

<script>
  (function () {
    var btn = document.getElementById('checkin-btn');
    if (!btn) return;
    var msg = document.getElementById('checkin-msg');

    function show(text, ok) {
      msg.innerHTML = '<div class="alert alert-' + (ok ? 'success' : 'danger') + ' py-2 mb-0">' + text + '</div>';
    }

    btn.addEventListener('click', function () {
      if (!navigator.geolocation) {
        show('当前浏览器不支持定位', false);
        return;
      }
      btn.disabled = true;
      btn.textContent = '定位中…';
      navigator.geolocation.getCurrentPosition(function (pos) {
        fetch('/event/<%= event.id %>/checkin', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            lat: pos.coords.latitude,
            lng: pos.coords.longitude
          })
        }).then(function (r) {
          return r.json().then(function (data) {
            show(data.message, data.ok);
            if (data.ok) {
              setTimeout(function () { location.reload(); }, 1200);
            } else {
              btn.disabled = false;
              btn.textContent = '📍 到场签到';
            }
          });
        }).catch(function () {
          show('网络错误，请重试', false);
          btn.disabled = false;
          btn.textContent = '📍 到场签到';
        });
      }, function (err) {
        show('无法获取位置：' + err.message + '（请允许定位权限）', false);
        btn.disabled = false;
        btn.textContent = '📍 到场签到';
      }, { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 });
    });
  })();
</script>
<%- include('partials/footer') %>
