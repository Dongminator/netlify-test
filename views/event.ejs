<%- include('partials/header') %>
<div class="pb-2 mt-2 mb-4 border-bottom">
  <h3><%= event.title %>
    <% if (isPast) { %><span class="badge badge-secondary">已结束</span><% } %>
  </h3>
</div>

<div class="row">
  <div class="col-md-8">
    <table class="table table-sm table-borderless">
      <tr><th class="text-nowrap" style="width:6rem">时间</th><td><%= event.date %> <%= event.time %></td></tr>
      <tr><th>地点</th><td><%= event.location %></td></tr>
      <tr><th>说明</th><td><%= event.description %></td></tr>
    </table>

    <% if (!isPast) { %>
      <% if (signedUp) { %>
        <form method="POST" action="/event/<%= event.id %>/withdraw" class="mb-3">
          <button class="btn btn-outline-danger" type="submit">取消报名</button>
          <span class="text-success ml-2">✓ 你已报名</span>
        </form>
        <% if (event.coords) { %>
          <div class="mb-4">
            <% if (checkedIn) { %>
              <span class="badge badge-success p-2">✓ 已到场签到</span>
            <% } else { %>
              <div id="field-map" class="rounded border mb-2" style="height: 260px;"></div>
              <div id="position-status" class="mb-2 text-muted">正在获取你的位置…</div>
              <button class="btn btn-success" id="checkin-btn" type="button" disabled>📍 到场签到</button>
              <small class="text-muted ml-2">进入绿圈（球场 <%= checkinRadius %> 米范围）后即可签到</small>
              <div id="checkin-msg" class="mt-2"></div>
            <% } %>
          </div>
        <% } %>
      <% } else if (event.signups.length >= event.capacity) { %>
        <p class="text-danger mb-4">报名人数已满</p>
      <% } else { %>
        <form method="POST" action="/event/<%= event.id %>/signup" class="mb-4">
          <button class="btn btn-primary" type="submit">报名</button>
        </form>
      <% } %>
    <% } %>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-header">报名名单 (<%= participants.length %> / <%= event.capacity %>)</div>
      <ul class="list-group list-group-flush">
        <% if (participants.length === 0) { %>
          <li class="list-group-item text-muted">还没有人报名</li>
        <% } %>
        <% participants.forEach((p, i) => { %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span><%= i + 1 %>. <%= p.name %></span>
            <% if (p.checkedIn) { %><span class="badge badge-success">已签到</span><% } %>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>
</div>

<% if (signedUp && !checkedIn && !isPast && event.coords) { %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  (function () {
    var FIELD = { lat: <%= event.coords.lat %>, lng: <%= event.coords.lng %> };
    var RADIUS = <%= checkinRadius %>;
    var btn = document.getElementById('checkin-btn');
    var msg = document.getElementById('checkin-msg');
    var status = document.getElementById('position-status');
    var lastPos = null;
    var userMarker = null;
    var accuracyCircle = null;

    var map = L.map('field-map').setView([FIELD.lat, FIELD.lng], 17);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);
    L.marker([FIELD.lat, FIELD.lng]).addTo(map).bindPopup('⚽ 球场签到点');
    var boundary = L.circle([FIELD.lat, FIELD.lng], {
      radius: RADIUS, color: '#28a745', fillColor: '#28a745', fillOpacity: 0.15
    }).addTo(map);
    map.fitBounds(boundary.getBounds(), { maxZoom: 19, padding: [20, 20] });

    function distanceMeters(lat1, lng1, lat2, lng2) {
      var R = 6371000, toRad = function (d) { return d * Math.PI / 180; };
      var dLat = toRad(lat2 - lat1), dLng = toRad(lng2 - lng1);
      var a = Math.sin(dLat / 2) * Math.sin(dLat / 2)
        + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLng / 2) * Math.sin(dLng / 2);
      return 2 * R * Math.asin(Math.sqrt(a));
    }

    function show(text, ok) {
      msg.innerHTML = '<div class="alert alert-' + (ok ? 'success' : 'danger') + ' py-2 mb-0">' + text + '</div>';
    }

    function onPosition(pos) {
      lastPos = pos;
      var lat = pos.coords.latitude, lng = pos.coords.longitude;
      if (!userMarker) {
        userMarker = L.circleMarker([lat, lng], {
          radius: 7, color: '#fff', weight: 2, fillColor: '#007bff', fillOpacity: 1
        }).addTo(map).bindPopup('你的位置');
        accuracyCircle = L.circle([lat, lng], {
          radius: pos.coords.accuracy, color: '#007bff', weight: 1, fillOpacity: 0.08
        }).addTo(map);
        map.fitBounds(L.latLngBounds([[lat, lng], [FIELD.lat, FIELD.lng]]).pad(0.3), { maxZoom: 19 });
      } else {
        userMarker.setLatLng([lat, lng]);
        accuracyCircle.setLatLng([lat, lng]).setRadius(pos.coords.accuracy);
      }
      var d = Math.round(distanceMeters(lat, lng, FIELD.lat, FIELD.lng));
      var inside = d <= RADIUS;
      btn.disabled = !inside;
      status.className = 'mb-2 ' + (inside ? 'text-success font-weight-bold' : 'text-muted');
      status.textContent = inside
        ? '✓ 已进入签到范围（距中心 ' + d + ' 米），可以签到'
        : '距签到点 ' + d + ' 米，进入绿圈后可签到（定位精度 ±' + Math.round(pos.coords.accuracy) + ' 米）';
    }

    if (!navigator.geolocation) {
      status.textContent = '当前浏览器不支持定位，无法签到';
      status.className = 'mb-2 text-danger';
    } else {
      navigator.geolocation.watchPosition(onPosition, function (err) {
        status.textContent = '无法获取位置：' + err.message + '（请允许定位权限后刷新页面）';
        status.className = 'mb-2 text-danger';
      }, { enableHighAccuracy: true, timeout: 15000, maximumAge: 5000 });
    }

    btn.addEventListener('click', function () {
      if (!lastPos) return;
      btn.disabled = true;
      btn.textContent = '签到中…';
      fetch('/event/<%= event.id %>/checkin', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          lat: lastPos.coords.latitude,
          lng: lastPos.coords.longitude
        })
      }).then(function (r) {
        return r.json().then(function (data) {
          show(data.message, data.ok);
          if (data.ok) {
            setTimeout(function () { location.reload(); }, 1200);
          } else {
            btn.disabled = false;
            btn.textContent = '📍 到场签到';
          }
        });
      }).catch(function () {
        show('网络错误，请重试', false);
        btn.disabled = false;
        btn.textContent = '📍 到场签到';
      });
    });
  })();
</script>
<% } %>
<%- include('partials/footer') %>
