<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#4DA5F4">
  <title><%= title %> - GSF App</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.2/css/all.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/soccer/custom-football-squad.css">
</head>
<body>
<div class="navbar navbar-light fixed-top navbar-expand-lg bg-light">
  <div class="container">
    <a class="navbar-brand" href="/">⚽ GSF俱乐部会员App</a>
    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target=".navbar-collapse">
      <span class="sr-only">Toggle navigation</span>
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse">
      <ul class="nav navbar-nav">
        <li class="nav-item<%= path === '/calendar' ? ' active' : '' %>"><a class="nav-link" href="/calendar">活动日历</a></li>
        <li class="nav-item<%= path === '/member-list' ? ' active' : '' %>"><a class="nav-link" href="/member-list">会员列表</a></li>
      </ul>
      <ul class="nav navbar-nav ml-auto">
        <% if (user) { %>
          <li class="nav-item"><span class="nav-link text-muted"><%= user.name %></span></li>
          <li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li>
        <% } else { %>
          <li class="nav-item<%= path === '/login' ? ' active' : '' %>"><a class="nav-link" href="/login">Login</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</div>
<div class="container main-content">
